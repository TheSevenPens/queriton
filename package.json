{
	"name": "@thesevenpens/queriton",
	"version": "0.1.0",
	"description": "Lazy, typed pipeline-of-verb-steps query API for in-memory JSON-shaped collections.",
	"license": "ISC",
	"author": "TheSevenPens",
	"repository": {
		"type": "git",
		"url": "https://github.com/TheSevenPens/queriton.git"
	},
	"homepage": "https://github.com/TheSevenPens/queriton#readme",
	"bugs": "https://github.com/TheSevenPens/queriton/issues",
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"keywords": [
		"query",
		"pipeline",
		"dplyr",
		"summarize",
		"groupby",
		"lazy",
		"typescript",
		"dataset",
		"verbs",
		"in-memory"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"files": [
		"src",
		"README.md"
	],
	"scripts": {
		"build-tutorial-tests": "node scripts/build-tutorial-tests.mjs",
		"pretest": "node scripts/build-tutorial-tests.mjs",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"vitest": "^4.1.5"
	}
}
